# ============================================================
# Zotero connection
# ============================================================
# Two ways to connect. Pick ONE.
#
# (A) LOCAL API  — easiest. Uses the running Zotero 7 desktop app.
#     No API key needed; PDFs are read straight off your disk.
#     In Zotero: Settings -> Advanced -> enable
#       "Allow other applications on this computer to communicate with Zotero".
ZOTERO_LOCAL=true
ZOTERO_LIBRARY_ID=0
ZOTERO_LIBRARY_TYPE=user

# (B) WEB API — works against the Zotero cloud library.
#     Set ZOTERO_LOCAL=false and fill these in.
#     Library ID:  https://www.zotero.org/settings/keys  ("Your userID for use in API calls")
#     API key:     https://www.zotero.org/settings/keys/new  (needs library read + write)
#     PDF download via the Web API requires the files to be synced to Zotero storage.
# ZOTERO_LOCAL=false
# ZOTERO_LIBRARY_ID=1234567
# ZOTERO_LIBRARY_TYPE=user        # "user" or "group"
# ZOTERO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Optional fallback: absolute path to your Zotero "storage" folder.
# If a PDF can't be fetched through the API, it's read from here instead.
# Default Zotero data dir on macOS: ~/Zotero/storage
# ZOTERO_STORAGE_DIR=/Users/you/Zotero/storage

# ============================================================
# LLM  (default: DeepSeek)
# ============================================================
# The API key is resolved in this order (highest precedence first):
#   1. CLI flag:              --llm-api-key sk-...
#   2. Generic override:      LLM_API_KEY=sk-...   (any provider)
#   3. Provider's env var:    DEEPSEEK_API_KEY / OPENAI_API_KEY / GOOGLE_API_KEY
# Use (3) — the standard names — if you already export these keys globally in
# your shell; you then don't need to repeat them here. Ollama needs no key.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-your-deepseek-key
LLM_TEMPERATURE=0.2

# --- Google Gemini ---
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=...

# --- Local, free: Ollama (e.g. qwen3:8b) ---
# Requires the Ollama app running and the model pulled: `ollama pull qwen3:8b`
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3:8b
# LLM_BASE_URL=http://127.0.0.1:11434      # optional; this is the default
#   (use 127.0.0.1, not localhost — localhost may resolve to IPv6/Docker)

# --- Any OpenAI-compatible endpoint (OpenAI, Together, vLLM, ...) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1

# Max characters of PDF text sent to the model (keeps you inside the context window).
MAX_PDF_CHARS=48000
